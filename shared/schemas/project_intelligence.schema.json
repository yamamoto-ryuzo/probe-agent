{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://probe-agent.dev/schemas/project_intelligence.json",
  "title": "Project Intelligence API Contracts",
  "description": "Reusable schemas for the repository intelligence, probe planning, validation, and experiment APIs.",
  "definitions": {
    "FeatureEvidence": {
      "type": "object",
      "required": ["path", "start_line", "end_line", "summary"],
      "properties": {
        "path": { "type": "string" },
        "start_line": { "type": "integer", "minimum": 0 },
        "end_line": { "type": "integer", "minimum": 0 },
        "summary": { "type": "string" }
      },
      "additionalProperties": false
    },
    "RepositoryConfig": {
      "type": "object",
      "required": ["system_id", "repo_path", "include_patterns", "exclude_patterns"],
      "properties": {
        "system_id": { "type": "integer" },
        "repo_path": { "type": "string" },
        "include_patterns": { "type": "array", "items": { "type": "string" } },
        "exclude_patterns": { "type": "array", "items": { "type": "string" } },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      }
    },
    "SnapshotFile": {
      "type": "object",
      "required": ["path", "source_type", "size_bytes"],
      "properties": {
        "path": { "type": "string" },
        "source_type": { "enum": ["documentation", "source", "test", "configuration"] },
        "size_bytes": { "type": "integer", "minimum": 0 },
        "inclusion_status": { "enum": ["indexed", "metadata_only", "too_large", "binary"], "default": "indexed" },
        "exclusion_reason": { "type": "string", "default": "" }
      },
      "additionalProperties": false
    },
    "Snapshot": {
      "type": "object",
      "required": ["id", "system_id", "repo_path", "commit_sha", "status", "file_count", "total_size"],
      "properties": {
        "id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "repo_path": { "type": "string" },
        "commit_sha": { "type": "string" },
        "status": { "enum": ["not_configured", "indexing", "ready", "failed"] },
        "file_count": { "type": "integer", "minimum": 0 },
        "total_size": { "type": "integer", "minimum": 0 },
        "indexed_size": { "type": "integer", "minimum": 0, "default": 0 },
        "metadata_only_count": { "type": "integer", "minimum": 0, "default": 0 },
        "warnings": { "type": "array", "items": { "type": "string" }, "default": [] },
        "error_summary": { "type": ["string", "null"] },
        "created_at": { "type": "number" },
        "completed_at": { "type": ["number", "null"] },
        "files": { "type": "array", "items": { "$ref": "#/definitions/SnapshotFile" } }
      }
    },
    "IntelligenceRun": {
      "type": "object",
      "required": ["id", "system_id", "snapshot_id", "run_type", "provider", "model", "decision_method", "status"],
      "properties": {
        "id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "run_type": { "enum": ["repository_drafts", "system_profile_draft", "feature_map_draft", "symbol_index", "feature_code_mapping", "probe_plan"] },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "prompt_version": { "type": "string" },
        "schema_version": { "type": "string" },
        "decision_method": { "enum": ["deterministic", "reasoning_llm", "manual"] },
        "status": { "enum": ["pending", "completed", "failed"] },
        "error_details": { "type": ["string", "null"] },
        "is_mock": { "type": "boolean" },
        "started_at": { "type": "number" },
        "completed_at": { "type": ["number", "null"] }
      }
    },
    "SystemProfileDraft": {
      "type": "object",
      "required": ["id", "system_id", "intelligence_run_id", "snapshot_id"],
      "properties": {
        "id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "intelligence_run_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "name": { "type": "string" },
        "purpose": { "type": "string" },
        "target_users": { "type": "array", "items": { "type": "string" } },
        "stakeholder_value": { "type": "string" },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "success_criteria": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/definitions/FeatureEvidence" } },
        "is_mock": { "type": "boolean" },
        "created_at": { "type": "number" }
      }
    },
    "FeatureDraft": {
      "type": "object",
      "required": ["id", "system_id", "intelligence_run_id", "snapshot_id", "feature_id", "name"],
      "properties": {
        "id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "intelligence_run_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "feature_id": { "type": "string" },
        "name": { "type": "string" },
        "summary": { "type": "string" },
        "user_value": { "type": "string" },
        "success_criteria": { "type": "array", "items": { "type": "string" } },
        "risks": { "type": "array", "items": { "type": "string" } },
        "evidence": { "type": "array", "items": { "$ref": "#/definitions/FeatureEvidence" } },
        "decision_method": { "enum": ["deterministic", "reasoning_llm", "manual"] },
        "is_mock": { "type": "boolean" },
        "created_at": { "type": "number" }
      }
    },
    "SourceMetadata": {
      "type": "object",
      "description": "Author-written, source-anchored explanation copied verbatim from a docstring probe-agent block. Kept separate from reasoning-model output; origin is always source_authored.",
      "required": ["start_line", "end_line", "raw_block"],
      "properties": {
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "raw_block": { "type": "string" },
        "role": { "type": ["string", "null"] },
        "capability": { "type": ["string", "null"] },
        "element_type": {
          "type": ["string", "null"],
          "enum": ["system", "core", "capability", "element", "supporting", "boundary", null]
        },
        "system_purpose": { "type": ["string", "null"] },
        "operation_kind": {
          "type": ["string", "null"],
          "enum": ["analysis", "read", "write", "mutation", "io", "orchestration", "validation", "other", null]
        },
        "consumers": { "type": "array", "items": { "type": "string" } },
        "state_effects": { "type": "array", "items": { "type": "string" } },
        "probe_value": { "type": ["string", "null"] },
        "origin": { "enum": ["source_authored"] },
        "explanation_hash": {
          "type": ["string", "null"],
          "description": "sha256 of the extracted explanation block. A change signal only; not semantic equality."
        }
      },
      "additionalProperties": false
    },
    "ExplanationAnchor": {
      "type": "object",
      "description": "A deterministic source anchor an explanation depends on (file, symbol span, and hash provenance). Used by downstream drift features; hash equality is only a change signal.",
      "required": ["id", "snapshot_id", "system_id", "metadata_id", "symbol_id", "path", "qualified_name", "start_line", "end_line"],
      "properties": {
        "id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "metadata_id": { "type": "integer" },
        "symbol_id": { "type": "integer" },
        "path": { "type": "string" },
        "qualified_name": { "type": "string" },
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "file_content_hash": { "type": ["string", "null"] },
        "symbol_source_hash": { "type": ["string", "null"] },
        "symbol_body_hash": { "type": ["string", "null"] },
        "explanation_hash": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "CodeSymbol": {
      "type": "object",
      "required": ["id", "snapshot_id", "system_id", "path", "qualified_name", "kind", "start_line", "end_line"],
      "properties": {
        "id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "path": { "type": "string" },
        "qualified_name": { "type": "string" },
        "kind": { "enum": ["module", "class", "function", "async_function"] },
        "start_line": { "type": "integer", "minimum": 1 },
        "end_line": { "type": "integer", "minimum": 1 },
        "decorators": { "type": "array", "items": { "type": "string" } },
        "imports": { "type": "array", "items": { "type": "string" } },
        "docstring": { "type": ["string", "null"] },
        "is_test": { "type": "boolean" },
        "is_pydantic_model": { "type": "boolean" },
        "route_path": { "type": ["string", "null"] },
        "route_method": { "type": ["string", "null"] },
        "component_id": { "type": ["string", "null"] },
        "source_metadata": {
          "oneOf": [
            { "$ref": "#/definitions/SourceMetadata" },
            { "type": "null" }
          ]
        },
        "file_content_hash": {
          "type": ["string", "null"],
          "description": "sha256 of the committed file content for the symbol's path in the pinned snapshot."
        },
        "symbol_source_hash": {
          "type": ["string", "null"],
          "description": "sha256 of the symbol's exact source span (signature + body, as committed)."
        },
        "symbol_body_hash": {
          "type": ["string", "null"],
          "description": "sha256 of a normalized AST with docstring removed and comments/formatting excluded."
        }
      },
      "additionalProperties": false
    },
    "FeatureCodeLink": {
      "type": "object",
      "required": ["id", "system_id", "snapshot_id", "intelligence_run_id", "feature_id", "symbol", "relation_reason", "confidence", "source", "review_status"],
      "properties": {
        "id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "intelligence_run_id": { "type": "integer" },
        "feature_id": { "type": "string" },
        "symbol": { "$ref": "#/definitions/CodeSymbol" },
        "relation_reason": { "type": "string" },
        "confidence": { "type": "number", "minimum": 0.0, "maximum": 1.0 },
        "source": { "enum": ["reasoning_llm", "manual"] },
        "review_status": { "enum": ["proposed", "accepted", "rejected"] },
        "provider": { "type": "string" },
        "model": { "type": "string" },
        "prompt_version": { "type": "string" },
        "schema_version": { "type": "string" },
        "is_stale": { "type": "boolean" },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ProbePoint": {
      "type": "object",
      "required": ["id", "plan_id", "system_id", "component_id", "feature_id", "path", "symbol", "line_start", "line_end", "reason", "recommended_mode", "side_effect_risk", "replayability", "status"],
      "properties": {
        "id": { "type": "integer" },
        "plan_id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "component_id": { "type": "string" },
        "feature_id": { "type": "string" },
        "path": { "type": "string" },
        "symbol": { "type": "string" },
        "line_start": { "type": "integer", "minimum": 1 },
        "line_end": { "type": "integer", "minimum": 1 },
        "reason": { "type": "string" },
        "recommended_mode": { "enum": ["trace", "shadow"] },
        "side_effect_risk": { "enum": ["none", "low", "medium", "high"] },
        "replayability": { "enum": ["safe", "caution", "unsafe"] },
        "denylist_hit": { "type": ["string", "null"] },
        "status": { "enum": ["proposed", "approved", "rejected"] },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ProbePlan": {
      "type": "object",
      "required": ["id", "system_id", "snapshot_id", "intelligence_run_id", "feature_id", "objective", "status"],
      "properties": {
        "id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "intelligence_run_id": { "type": "integer" },
        "feature_id": { "type": "string" },
        "objective": { "type": "string" },
        "status": { "enum": ["proposed", "approved", "rejected"] },
        "avoid_reasons": { "type": "array", "items": { "type": "string" } },
        "probe_points": { "type": "array", "items": { "$ref": "#/definitions/ProbePoint" } },
        "intelligence_run": { "$ref": "#/definitions/IntelligenceRun" },
        "created_at": { "type": "number" },
        "updated_at": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ProbePatch": {
      "type": "object",
      "required": ["id", "plan_id", "system_id", "snapshot_id", "commit_sha", "status"],
      "properties": {
        "id": { "type": "integer" },
        "plan_id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "commit_sha": { "type": "string" },
        "diff": { "type": "string" },
        "worktree_path": { "type": "string" },
        "skipped": { "type": "array", "items": { "type": "string" } },
        "status": { "enum": ["generated", "failed"] },
        "error": { "type": ["string", "null"] },
        "cleanup_state": { "type": "string" },
        "cleanup_error": { "type": ["string", "null"] },
        "validation_runs": { "type": "array", "items": { "$ref": "#/definitions/ValidationRun" } },
        "created_at": { "type": "number" }
      },
      "additionalProperties": false
    },
    "ValidationCommand": {
      "type": "object",
      "required": ["id", "run_id", "command", "exit_code", "duration_ms"],
      "properties": {
        "id": { "type": "integer" },
        "run_id": { "type": "integer" },
        "command": { "type": "string" },
        "exit_code": { "type": "integer" },
        "duration_ms": { "type": "number" },
        "stdout": { "type": "string" },
        "stderr": { "type": "string" },
        "stdout_truncated": { "type": "boolean" },
        "stderr_truncated": { "type": "boolean" },
        "timed_out": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "ValidationRun": {
      "type": "object",
      "required": ["id", "patch_id", "system_id", "variant", "overall_success"],
      "properties": {
        "id": { "type": "integer" },
        "patch_id": { "type": "integer" },
        "system_id": { "type": "integer" },
        "variant": { "enum": ["baseline", "probed"] },
        "worktree_path": { "type": "string" },
        "overall_success": { "type": "boolean" },
        "total_duration_ms": { "type": "number" },
        "trace_received": { "type": ["boolean", "null"] },
        "trace_status": { "type": "string" },
        "network_isolation": { "type": "string" },
        "cleanup_state": { "type": "string" },
        "cleanup_error": { "type": ["string", "null"] },
        "error": { "type": ["string", "null"] },
        "commands": { "type": "array", "items": { "$ref": "#/definitions/ValidationCommand" } },
        "created_at": { "type": "number" }
      },
      "additionalProperties": false
    },
    "HierarchyProvenance": {
      "type": "object",
      "description": "Provenance for a single capability-hierarchy claim. provenance_kind distinguishes source-authored explanation, deterministic structural fact, and reasoning interpretation; decision_method is the audit enum.",
      "required": ["provenance_kind", "decision_method"],
      "properties": {
        "provenance_kind": { "enum": ["source_authored", "structural", "reasoning_llm", "manual"] },
        "decision_method": { "enum": ["deterministic", "reasoning_llm", "manual"] },
        "path": { "type": ["string", "null"] },
        "qualified_name": { "type": ["string", "null"] },
        "start_line": { "type": ["integer", "null"] },
        "end_line": { "type": ["integer", "null"] },
        "file_content_hash": { "type": ["string", "null"] },
        "symbol_source_hash": { "type": ["string", "null"] },
        "explanation_hash": { "type": ["string", "null"] },
        "symbol_id": { "type": ["integer", "null"] },
        "entrypoint_id": { "type": ["integer", "null"] },
        "feature_id": { "type": ["string", "null"] },
        "system_profile_draft_id": { "type": ["integer", "null"] },
        "provider": { "type": ["string", "null"] },
        "model": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "SupportingElement": {
      "type": "object",
      "required": ["id", "name", "provenance"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "summary": { "type": "string" },
        "supporting_kind": { "type": ["string", "null"] },
        "provenance": { "$ref": "#/definitions/HierarchyProvenance" }
      },
      "additionalProperties": false
    },
    "CapabilityElement": {
      "type": "object",
      "required": ["id", "name", "provenance"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "summary": { "type": "string" },
        "element_role": { "type": ["string", "null"] },
        "operation_kind": { "type": ["string", "null"] },
        "probe_value": { "type": ["string", "null"] },
        "classification": { "type": ["string", "null"], "enum": ["classified", "unclassified", null] },
        "provenance": { "$ref": "#/definitions/HierarchyProvenance" }
      },
      "additionalProperties": false
    },
    "Capability": {
      "type": "object",
      "required": ["id", "name", "provenance"],
      "properties": {
        "id": { "type": "integer" },
        "capability_key": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "summary": { "type": "string" },
        "provenance": { "$ref": "#/definitions/HierarchyProvenance" },
        "elements": { "type": "array", "items": { "$ref": "#/definitions/CapabilityElement" } },
        "supporting_elements": { "type": "array", "items": { "$ref": "#/definitions/SupportingElement" } }
      },
      "additionalProperties": false
    },
    "CapabilityPurpose": {
      "type": "object",
      "required": ["id", "name", "provenance"],
      "properties": {
        "id": { "type": "integer" },
        "name": { "type": "string" },
        "summary": { "type": "string" },
        "provenance": { "$ref": "#/definitions/HierarchyProvenance" }
      },
      "additionalProperties": false
    },
    "CapabilityHierarchy": {
      "type": "object",
      "required": ["system_id", "snapshot_id"],
      "properties": {
        "system_id": { "type": "integer" },
        "snapshot_id": { "type": "integer" },
        "intelligence_run": { "oneOf": [{ "$ref": "#/definitions/IntelligenceRun" }, { "type": "null" }] },
        "purpose": { "oneOf": [{ "$ref": "#/definitions/CapabilityPurpose" }, { "type": "null" }] },
        "capabilities": { "type": "array", "items": { "$ref": "#/definitions/Capability" } },
        "unclassified_elements": { "type": "array", "items": { "$ref": "#/definitions/CapabilityElement" } },
        "unattached_supporting": { "type": "array", "items": { "$ref": "#/definitions/SupportingElement" } },
        "is_mock": { "type": "boolean" }
      },
      "additionalProperties": false
    },
    "DriftCounts": {
      "type": "object",
      "description": "Drift dependency counts and ratios for a capability/system. Hash drift is a review trigger, not a correctness verdict.",
      "properties": {
        "total": { "type": "integer" },
        "fresh": { "type": "integer" },
        "stale": { "type": "integer" },
        "missing": { "type": "integer" },
        "unknown": { "type": "integer" },
        "symbol_deps_total": { "type": "integer" },
        "symbol_deps_changed": { "type": "integer" },
        "file_deps_total": { "type": "integer" },
        "file_deps_changed": { "type": "integer" },
        "explanation_blocks_total": { "type": "integer" },
        "explanation_blocks_changed": { "type": "integer" },
        "missing_anchors": { "type": "integer" },
        "mismatch_ratio": { "type": "number" }
      },
      "additionalProperties": false
    },
    "AnchorDrift": {
      "type": "object",
      "required": ["node_id", "node_type", "name", "status"],
      "properties": {
        "node_id": { "type": "integer" },
        "node_type": { "type": "string" },
        "name": { "type": "string" },
        "path": { "type": ["string", "null"] },
        "qualified_name": { "type": ["string", "null"] },
        "entrypoint_id": { "type": ["integer", "null"] },
        "status": { "enum": ["fresh", "partially_stale", "stale", "missing_source", "unknown"] },
        "changed_hashes": { "type": "array", "items": { "type": "string" } },
        "captured_file_content_hash": { "type": ["string", "null"] },
        "captured_symbol_source_hash": { "type": ["string", "null"] },
        "captured_explanation_hash": { "type": ["string", "null"] },
        "current_file_content_hash": { "type": ["string", "null"] },
        "current_symbol_source_hash": { "type": ["string", "null"] },
        "current_explanation_hash": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "CapabilityDrift": {
      "type": "object",
      "required": ["capability_id", "name", "status", "counts"],
      "properties": {
        "capability_id": { "type": "integer" },
        "capability_key": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "status": { "enum": ["fresh", "partially_stale", "stale", "missing_source", "unknown"] },
        "counts": { "$ref": "#/definitions/DriftCounts" },
        "elements": { "type": "array", "items": { "$ref": "#/definitions/AnchorDrift" } },
        "supporting_elements": { "type": "array", "items": { "$ref": "#/definitions/AnchorDrift" } }
      },
      "additionalProperties": false
    },
    "CapabilityHierarchyDrift": {
      "type": "object",
      "required": ["system_id", "base_snapshot_id", "target_snapshot_id", "status", "counts"],
      "properties": {
        "system_id": { "type": "integer" },
        "base_snapshot_id": { "type": "integer" },
        "target_snapshot_id": { "type": "integer" },
        "intelligence_run": { "oneOf": [{ "$ref": "#/definitions/IntelligenceRun" }, { "type": "null" }] },
        "status": { "enum": ["fresh", "partially_stale", "stale", "missing_source", "unknown"] },
        "counts": { "$ref": "#/definitions/DriftCounts" },
        "target_indexed": { "type": "boolean" },
        "purpose": { "oneOf": [{ "$ref": "#/definitions/AnchorDrift" }, { "type": "null" }] },
        "capabilities": { "type": "array", "items": { "$ref": "#/definitions/CapabilityDrift" } },
        "unclassified_elements": { "type": "array", "items": { "$ref": "#/definitions/AnchorDrift" } },
        "unattached_supporting": { "type": "array", "items": { "$ref": "#/definitions/AnchorDrift" } },
        "is_review_recommended": { "type": "boolean" },
        "review_note": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "ApiRoleCard": {
      "type": "object",
      "description": "Flow Explorer developer context for one backend entrypoint (Issue #58). Aggregates source-authored explanation (#54), hierarchy placement (#56), and drift (#57). Joins to FlowEntrypoint by (entrypoint_type, entrypoint_id).",
      "required": ["entrypoint_type", "entrypoint_id", "label", "classification"],
      "properties": {
