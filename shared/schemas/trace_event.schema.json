{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://probe-agent.dev/schemas/trace_event.json",
  "title": "TraceEvent",
  "type": "object",
  "required": ["trace_id", "component_id", "timestamp"],
  "properties": {
    "trace_id":     { "type": "string" },
    "component_id": { "type": "string" },
    "mode":         { "type": ["string", "null"], "enum": ["off", "trace", "shadow", null] },
    "input": {
      "type": ["object", "null"],
      "properties": {
        "args":   { "type": "array", "items": { "type": "string" } },
        "kwargs": { "type": "object", "additionalProperties": { "type": "string" } }
      }
    },
    "output":      { "type": ["string", "null"] },
    "error":       { "type": ["string", "null"] },
    "duration_ms": { "type": "number", "minimum": 0 },
    "timestamp":   { "type": "number" }
  },
  "additionalProperties": false
}
