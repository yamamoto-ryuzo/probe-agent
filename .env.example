# Copy this file to .env and edit values for your local environment.
#
# Docker Compose automatically reads .env from the repository root and uses
# these values in docker-compose.yml.

# Dashboard -> Control Server URL.
# For Docker Compose, keep the service URL below.
# For host-local scripts, use http://localhost:8000 in the script environment.
PROBE_SERVER_URL=http://control-server:8000

# Optional legacy API keys accepted by Control Server.
# Leave empty to run without auth unless admin users already exist.
# Multiple keys can be comma-separated.
CONTROL_API_KEYS=dev-secret-key

# Dashboard API key sent as X-Api-Key to Control Server.
# For simple local development, set this to the same value as CONTROL_API_KEYS.
DASHBOARD_API_KEY=dev-secret-key

# Set true when the Dashboard is served over HTTPS.
DASHBOARD_COOKIE_SECURE=false

# URL shown to SDK users in the Dashboard's Connect SDK tab.
# In Docker Compose, PROBE_SERVER_URL points to the internal service name, but
# host-local clients usually need http://localhost:8000.
PROBE_CLIENT_SERVER_URL=http://localhost:8000

# SDK install target shown in the Dashboard's Connect SDK tab.
PROBE_SDK_INSTALL_URL=git+https://github.com/dx-junkyard/probe-agent.git@main#subdirectory=packages/python-probe

# Optional bootstrap admin user. On first startup, Control Server creates this
# user if it does not already exist.
CONTROL_ADMIN_USERNAME=admin
CONTROL_ADMIN_PASSWORD=change-me

# LLM used by Generate & Evaluate.
# Supported providers: openai, anthropic, gemini, mock.
# Set LLM_PROVIDER=mock only for local smoke tests; it does not call an external LLM.
LLM_PROVIDER=openai
LLM_MODEL=gpt-5.4-mini
LLM_API_KEY=
LLM_BASE_URL=
LLM_TIMEOUT=30

# Feature Intelligence の自由度のある推論には reasoning model が必須。
# 未設定・API failure 時に heuristic へ fallback しない。
INTELLIGENCE_LLM_MODEL=gpt-5.4
INTELLIGENCE_ALLOW_HEURISTIC_FALLBACK=false

# Host側のRepository群を配置した絶対パス。
# ユーザー名や案件名を含み得るため、実値はGitへcommitしないこと。
# 通常の解析はcommitted filesだけを読み、承認済みProbe PatchのApply時だけ
# このmountへ書き込む。
PROBE_REPOSITORY_HOST_ROOT=/absolute/path/to/repositories
